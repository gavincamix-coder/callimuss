<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AgroAI Enterprise - Intelligent Agronomy OS</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        /* --- Deep Technical Agronomy Theme Styling --- */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, Roboto, sans-serif;
        }

        body {
            background-color: #0b0f14;
            color: #e2e8f0;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
        }

        /* --- Global Structural Layout --- */
        header {
            background-color: #111823;
            border-bottom: 1px solid #1f293d;
            padding: 16px 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .brand-zone {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .logo-icon {
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            width: 32px;
            height: 32px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            color: #fff;
        }

        .brand-name {
            font-size: 1.25rem;
            font-weight: 700;
            letter-spacing: -0.5px;
        }

        .brand-badge {
            background-color: rgba(16, 185, 129, 0.15);
            color: #34d399;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .field-selector-wrapper {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        select.field-dropdown {
            background-color: #1f293d;
            border: 1px solid #374151;
            color: #fff;
            padding: 8px 16px;
            border-radius: 6px;
            outline: none;
            cursor: pointer;
            font-weight: 500;
        }

        /* --- Main Analytics Grid Architecture --- */
        .workspace {
            flex: 1;
            display: grid;
            grid-template-columns: 280px 1fr 360px;
            gap: 20px;
            padding: 20px;
            max-width: 1800px;
            width: 100%;
            margin: 0 auto;
        }

        /* Shared Dashboard Panel Card Design */
        .panel-card {
            background-color: #111823;
            border: 1px solid #1f293d;
            border-radius: 12px;
            padding: 20px;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .panel-title {
            font-size: 0.9rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #94a3b8;
            margin-bottom: 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        /* --- Left Side Control Navigation & Health Indexes --- */
        .health-index-box {
            background-color: #172030;
            border-radius: 8px;
            padding: 16px;
            margin-bottom: 12px;
            border-left: 4px solid #10b981;
        }

        .health-index-box.warning {
            border-left-color: #f59e0b;
        }

        .index-label {
            font-size: 0.8rem;
            color: #94a3b8;
        }

        .index-value {
            font-size: 1.5rem;
            font-weight: 700;
            color: #fff;
            margin-top: 4px;
        }

        /* --- Center Section: Satellite Maps & Live IoT Charts --- */
        .center-stream {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .map-mock-container {
            height: 320px;
            background: linear-gradient(45deg, #16222f 25%, #1a293b 25%, #1a293b 50%, #16222f 50%, #16222f 75%, #1a293b 75%, #1a293b 100%);
            background-size: 40px 40px;
            border-radius: 8px;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px dashed #374151;
        }

        .map-overlay-data {
            position: absolute;
            bottom: 16px;
            left: 16px;
            background-color: rgba(17, 24, 35, 0.9);
            padding: 12px;
            border-radius: 6px;
            border: 1px solid #1f293d;
            font-size: 0.8rem;
        }

        .map-indicator {
            width: 140px;
            height: 140px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(16,185,129,0.4) 0%, rgba(0,0,0,0) 70%);
            position: absolute;
            animation: pulse 3s infinite;
        }

        @keyframes pulse {
            0% { transform: scale(0.8); opacity: 0.5; }
            50% { transform: scale(1.2); opacity: 0.8; }
            100% { transform: scale(0.8); opacity: 0.5; }
        }

        .telemetry-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            flex: 1;
        }

        .chart-wrapper {
            background-color: #172030;
            padding: 12px;
            border-radius: 8px;
            height: 220px;
        }

        /* --- Right Section: Predictive Computer Vision Scanner & Chat --- */
        .ai-scanner-box {
            background-color: #172030;
            border: 1px solid #374151;
            border-radius: 8px;
            padding: 16px;
            text-align: center;
            margin-bottom: 20px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .ai-scanner-box:hover {
            border-color: #10b981;
            background-color: #1a2638;
        }

        .scanner-preview {
            width: 100%;
            height: 120px;
            background-color: #0b0f14;
            border-radius: 6px;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.85rem;
            color: #64748b;
            border: 2px dashed #1f293d;
            overflow: hidden;
            position: relative;
        }

        .scan-line {
            position: absolute;
            width: 100%;
            height: 2px;
            background-color: #10b981;
            top: 0;
            left: 0;
            animation: scan 2s linear infinite;
            display: none;
        }

        @keyframes scan {
            0% { top: 0%; }
            50% { top: 100%; }
            100% { top: 0%; }
        }

        .ai-chat-space {
            flex: 1;
            display: flex;
            flex-direction: column;
            background-color: #0b0f14;
            border-radius: 8px;
            border: 1px solid #1f293d;
            height: 300px;
        }

        .chat-history {
            flex: 1;
            padding: 12px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 10px;
            font-size: 0.85rem;
        }

        .chat-bubble {
            padding: 10px 12px;
            border-radius: 8px;
            max-width: 85%;
            line-height: 1.4;
        }

        .bubble-ai {
            background-color: #172030;
            color: #e2e8f0;
            align-self: flex-start;
            border-left: 3px solid #10b981;
        }

        .bubble-user {
            background-color: #10b981;
            color: #fff;
            align-self: flex-end;
        }

        .chat-input-wrapper {
            display: flex;
            border-top: 1px solid #1f293d;
            padding: 8px;
            background-color: #111823;
            border-radius: 0 0 8px 8px;
        }

        .chat-input-wrapper input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            padding: 8px;
            outline: none;
            font-size: 0.85rem;
        }

        .chat-input-wrapper button {
            background-color: #10b981;
            color: white;
            border: none;
            padding: 6px 12px;
            border-radius: 4px;
            cursor: pointer;
            font-weight: 600;
        }

        .chat-input-wrapper button:hover {
            background-color: #059669;
        }

        /* --- Utility & Response Layout Overrides --- */
        @media (max-width: 1100px) {
            .workspace {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>

    <header>
        <div class="brand-zone">
            <div class="logo-icon">🌿</div>
            <div class="brand-name">AgroAI Enterprise</div>
            <div class="brand-badge">V2.6 Powered</div>
        </div>
        <div class="field-selector-wrapper">
            <label style="font-size: 0.85rem; color: #94a3b8;">Active Parcel Node:</label>
            <select id="fieldSelect" class="field-dropdown" onchange="handleFieldChange()">
                <option value="field_alpha">Field Alpha - Zone 4A (Maize)</option>
                <option value="field_beta">Field Beta - Zone 1B (Soybeans)</option>
                <option value="field_gamma">Field Gamma - Central Pivot (Wheat)</option>
            </select>
        </div>
    </header>

    <div class="workspace">
        
        <aside class="panel-card">
            <div class="panel-title">Agronomic Node Health</div>
            
            <div class="health-index-box">
                <div class="index-label">NDVI Vegetation Index</div>
                <div class="index-value" id="ndviVal">0.78 Normal</div>
            </div>

            <div class="health-index-box" id="moistureCard">
                <div class="index-label">Volumetric Soil Moisture</div>
                <div class="index-value" id="moistureVal">34.2%</div>
            </div>

            <div class="health-index-box warning" id="stressCard">
                <div class="index-label">Crop Stress Probability</div>
                <div class="index-value" id="stressVal">14% Low</div>
            </div>

            <div class="health-index-box" style="border-left-color: #3b82f6;">
                <div class="index-label">Est. Nitrogen Saturation</div>
                <div class="index-value" id="nitrogenVal">48 kg/ha</div>
            </div>
        </aside>

        <main class="center-stream">
            <div class="panel-card" style="flex: initial;">
                <div class="panel-title">
                    Satellite Spatial Canopy Diagnostics
                    <span style="color: #10b981; font-size: 0.8rem;">● Live NDVI Pass</span>
                </div>
                <div class="map-mock-container">
                    <div class="map-indicator"></div>
                    <div class="map-overlay-data">
                        <strong>Resolution:</strong> 10m/pixel Multispectral<br>
                        <strong>Coordinates:</strong> 34.0522° N, 118.2437° W
                    </div>
                </div>
            </div>

            <div class="telemetry-grid">
                <div class="panel-card">
                    <div class="panel-title">Diurnal Soil Temp Trends (°C)</div>
                    <div class="chart-wrapper">
                        <canvas id="soilTempChart"></canvas>
                    </div>
                </div>
                <div class="panel-card">
                    <div class="panel-title">Evapotranspiration Capacity (mm)</div>
                    <div class="chart-wrapper">
                        <canvas id="evapoChart"></canvas>
                    </div>
                </div>
            </div>
        </main>

        <aside class="panel-card">
            <div class="panel-title">Computer Vision Plant Pathology</div>
            
            <div class="ai-scanner-box" onclick="triggerMockLeafScan()">
                <div class="scanner-preview" id="scanPreview">
                    <div class="scan-line" id="scanLine"></div>
                    <span id="scanPrompt">Click to Upload Tissue Image for Pathology Scan</span>
                </div>
                <button class="btn-primary" style="padding: 6px 12px; font-size: 0.8rem; border-radius: 4px; border:none; cursor:pointer;">Run Diagnostic Scan</button>
            </div>

            <div class="panel-title">Agronomy Copilot Agent</div>
            <div class="ai-chat-space">
                <div class="chat-history" id="chatHistory">
                    <div class="chat-bubble bubble-ai">
                        Hello. I have analyzed your active parcel telemetry array. Field Alpha Maize shows healthy development, though moisture margins are tightening. Ask me any strategic management question.
                    </div>
                </div>
                <div class="chat-input-wrapper">
                    <input type="text" id="chatInput" placeholder="Ask about fertilization, yield projections..." onkeypress="handleChatKey(event)">
                    <button onclick="sendChatMessage()">Query</button>
                </div>
            </div>
        </aside>
    </div>

    <script>
        // High Fidelity Telemetry Database Engine
        const fieldDatabase = {
            field_alpha: {
                ndvi: "0.78 Optimal", moisture: "34.2%", stress: "12% Low", stressWarn: false, nitrogen: "48 kg/ha",
                tempData: [21, 22, 24, 26, 25, 23, 21], evapoData: [4.1, 4.3, 4.6, 5.0, 4.8, 4.4, 4.2],
                aiResponse: "Field Alpha Maize requires no changes to N-P-K applications at present. Volumetric water content is ideal."
            },
            field_beta: {
                ndvi: "0.54 Critical", moisture: "18.1%", stress: "68% Severe Stress", stressWarn: true, nitrogen: "31 kg/ha",
                tempData: [26, 28, 31, 33, 32, 29, 27], evapoData: [6.2, 6.7, 7.1, 7.5, 7.2, 6.8, 6.4],
                aiResponse: "ALERT: Field Beta Soybeans are displaying extreme hydric deficiencies. Evapotranspiration is excessively high. Recommend immediate auxiliary pivot deployment."
            },
            field_gamma: {
                ndvi: "0.69 Moderate", moisture: "28.5%", stress: "29% Mild Stress", stressWarn: true, nitrogen: "55 kg/ha",
                tempData: [18, 19, 21, 22, 22, 20, 19], evapoData: [3.2, 3.4, 3.5, 3.8, 3.7, 3.5, 3.3],
                aiResponse: "Field Gamma Wheat exhibits standard root development patterns. Nitrogen saturation is stable."
            }
        };

        // UI Global Instantiations
        let tempChartInstance = null;
        let evapoChartInstance = null;

        function initTelemetryCharts() {
            const ctxTemp = document.getElementById('soilTempChart').getContext('2d');
            tempChartInstance = new Chart(ctxTemp, {
                type: 'line',
                data: {
                    labels: ['02:00', '06:00', '10:00', '14:00', '18:00', '22:00', 'Current'],
                    datasets: [{
                        label: 'Soil Temperature',
                        data: fieldDatabase.field_alpha.tempData,
                        borderColor: '#10b981',
                        backgroundColor: 'rgba(16, 185, 129, 0.05)',
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
            });

            const ctxEvapo = document.getElementById('evapoChart').getContext('2d');
            evapoChartInstance = new Chart(ctxEvapo, {
                type: 'bar',
                data: {
                    labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                    datasets: [{
                        label: 'Loss Rate',
                        data: fieldDatabase.field_alpha.evapoData,
                        backgroundColor: '#3b82f6',
                        borderRadius: 4
                    }]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
            });
        }

        // Field Value Switcher Pipeline
        function handleFieldChange() {
            const currentSelected = document.getElementById('fieldSelect').value;
            const dataNode = fieldDatabase[currentSelected];

            // Re-render Dom Elements
            document.getElementById('ndviVal').textContent = dataNode.ndvi;
            document.getElementById('moistureVal').textContent = dataNode.moisture;
            document.getElementById('stressVal').textContent = dataNode.stress;
            document.getElementById('nitrogenVal').textContent = dataNode.nitrogen;

            const stressCard = document.getElementById('stressCard');
            if(dataNode.stressWarn) {
                stressCard.classList.add('warning');
            } else {
                stressCard.classList.remove('warning');
            }

            // Update Graphical Nodes
            tempChartInstance.data.datasets[0].data = dataNode.tempData;
            tempChartInstance.update();

            evapoChartInstance.data.datasets[0].data = dataNode.evapoData;
            evapoChartInstance.update();

            // Inject system AI message
            const history = document.getElementById('chatHistory');
            history.innerHTML += `<div class="chat-bubble bubble-ai"><em>[System Alert System updated to ${currentSelected}]</em><br>${dataNode.aiResponse}</div>`;
            history.scrollTop = history.scrollHeight;
        }

        // Simulated Neural-Net Tissue Scanner Engine
        function triggerMockLeafScan() {
            const promptEl = document.getElementById('scanPrompt');
            const scanLine = document.getElementById('scanLine');
            
            promptEl.textContent = "Processing image matrix via CNN Pathology Net...";
            promptEl.style.color = "#34d399";
            scanLine.style.display = "block";

            setTimeout(() => {
                scanLine.style.display = "none";
                promptEl.innerHTML = "<strong style='color:#ef4444;'>Pathology Identified:</strong><br>Puccinia sorghi (Common Rust)<br>Severity: 24% Tissue Infestation";
                
                // Alert the AI chat element 
                const history = document.getElementById('chatHistory');
                history.innerHTML += `
                    <div class="chat-bubble bubble-ai">
                        <strong>AI Pathology Diagnostics Vector:</strong> Computer Vision has detected signs of Common Rust on your submission. Recommend applying localized triazole fungicide treatments within the next 48 hours to mitigate canopy degradation.
                    </div>`;
                history.scrollTop = history.scrollHeight;
            }, 2500);
        }

        // Chat Interface Interaction Logic
        function handleChatKey(event) {
            if (event.key === 'Enter') sendChatMessage();
        }

        function sendChatMessage() {
            const input = document.getElementById('chatInput');
            const text = input.value.trim();
            if (!text) return;

            const history = document.getElementById('chatHistory');
            
            // Render user bubble
            history.innerHTML += `<div class="chat-bubble bubble-user">${text}</div>`;
            input.value = '';

            // Generate contextual expert agronomy feedback
            setTimeout(() => {
                let responseText = "The localized weather forecast data indicates shifting precipitation cells. I recommend delaying mechanical operations to avoid extreme soil compaction compaction zones.";
                if(text.toLowerCase().includes('fertilizer') || text.toLowerCase().includes('nitrogen')) {
                    responseText = "Based on optimization metrics, target variable-rate application tracking. Apply a split dose of Urea at V6 growth phase for optimized metabolic uptake.";
                } else if(text.toLowerCase().includes('yield') || text.toLowerCase().includes('produce')) {
                    responseText = "Current predictive predictive data engines track this parcel node towards a 184 bushels/acre ceiling, assuming hydric metrics stay within standard parameters.";
                }

                history.innerHTML += `<div class="chat-bubble bubble-ai">${responseText}</div>`;
                history.scrollTop = history.scrollHeight;
            }, 1200);

            history.scrollTop = history.scrollHeight;
        }

        // Run instantiation loops on load
        window.onload = initTelemetryCharts;
    </script>
</body>
</html>
